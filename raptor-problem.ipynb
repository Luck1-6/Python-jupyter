    "01_sum of digit from 1 to 10"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "684323dc-9359-46e3-bbd7-50f962352de1",
   "metadata": {},
   "outputs": [],
   "source": [
    "def digit_sum(n):\n",
    "    sum_value = 0\n",
    "    for i in range(1, n+1):\n",
    "        sum_value +=i\n",
    "    return sum_value"
   ]
  },
